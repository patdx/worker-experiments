{
  "name": "cloudflare-pages-htmx",
  "version": "1.0.0",
  "description": "",
  "sideEffects": false,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nx start",
    "xx-dev": "nx dev",
    "x-dev": "pnpm build && wrangler pages dev ./dist/client --d1=DB --persist",
    "build": "nx exec -- vavite",
    "deploy": "rm -rf dist && vavite && wrangler pages deploy",
    "start": "nx exec -- wrangler pages dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/workers-types": "4.20240725.0",
    "@rollup/plugin-inject": "5.0.5",
    "@tailwindcss/forms": "0.5.9",
    "@tailwindcss/typography": "0.5.15",
    "@types/luxon": "3.4.2",
    "@types/node": "20.16.13",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.1",
    "@vavite/multibuild": "4.1.3",
    "@vavite/multibuild-cli": "4.1.3",
    "@vitejs/plugin-react": "4.3.3",
    "autoprefixer": "10.4.20",
    "json5": "2.2.3",
    "nx": "19.8.6",
    "open-cli": "8.0.0",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vavite": "4.1.3",
    "vite": "5.4.9",
    "vite-plugin-remix-routes": "0.4.1",
    "wrangler": "3.67.1"
  },
  "dependencies": {
    "@remix-run/router": "1.20.0",
    "clsx": "2.1.1",
    "htmx.org": "2.0.3",
    "luxon": "3.5.0",
    "preact": "10.24.3",
    "preact-render-to-string": "6.5.11",
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat",
    "react-icons": "5.3.0",
    "react-router": "6.27.0",
    "react-router-dom": "6.27.0"
  },
  "packageManager": "pnpm@9.12.2+sha512.22721b3a11f81661ae1ec68ce1a7b879425a1ca5b991c975b074ac220b187ce56c708fe5db69f4c962c989452eee76c82877f4ee80f474cebd61ee13461b6228",
  "nx": {
    "targets": {
      "start": {
        "dependsOn": [
          "build"
        ]
      },
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ],
        "cache": true
      },
      "dev": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "pnpm vite build --watch",
            "pnpm vite build --ssr --watch",
            "wrangler pages dev",
            "open-cli http://127.0.0.1:8788/"
          ],
          "parallel": true,
          "cwd": "packages/cloudflare-pages-htmx"
        }
      }
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "nx"
    ]
  }
}
